{
  "buildCommand": "chmod +x node_modules/.bin/tsc node_modules/.bin/vite && npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/hub-brief/:path*", "destination": "/api/hub-brief" },
    { "source": "/api/tickets/:path*", "destination": "/api/tickets" },
    { "source": "/api/hub/(.*)", "destination": "/api/hub" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
